@dp.message(BroadcastState.message)
async def broadcast_send(message: types.Message, state: FSMContext):
    users = cursor.execute("SELECT id FROM users WHERE is_blocked = 0").fetchall()
    sent = 0
    for user in users:
        try:
            if message.photo:
                await bot.send_photo(user[0], message.photo[-1].file_id, caption=message.caption)
            elif message.video:
                await bot.send_video(user[0], message.video.file_id, caption=message.caption)
            else:
                await bot.send_message(user[0], message.text, parse_mode="HTML")
            sent += 1
        except:
            pass
    await message.answer(f"✅ {sent}/{len(users)} ta foydalanuvchiga yuborildi!")
    await state.clear()

