# ========== MAJBURIY A'ZOLIK ==========
async def check_subscription(user_id):
    """Foydalanuvchi majburiy kanallarga a'zoligini tekshirish"""
    cursor.execute("SELECT channel_username, channel_type FROM forced_channels WHERE is_active = 1")
    channels = cursor.fetchall()
    if not channels:
        return True, []
    
    not_subscribed = []
    for channel_username, channel_type in channels:
        if channel_type == "telegram":
            clean_channel = channel_username.replace('@', '').strip()
            if not clean_channel:
                continue
            try:
                member = await bot.get_chat_member(chat_id=f"@{clean_channel}", user_id=user_id)
                if member.status in ['left', 'kicked']:
                    not_subscribed.append({"type": channel_type, "username": channel_username})
            except Exception as e:
                print(f"⚠️ Kanal tekshirish xatosi {channel_username}: {e}")
        else:
            # Instagram va YouTube uchun faqat link ko'rsatiladi, tekshirilmaydi
            # Foydalanuvchi o'zi a'zo bo'lishi kerak
            not_subscribed.append({"type": channel_type, "username": channel_username})
    
    return len(not_subscribed) == 0, not_subscribed

