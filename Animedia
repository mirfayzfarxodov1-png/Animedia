@dp.message(Command("start"))
async def start(message: types.Message):
    await add_user(message.from_user)
    
    is_subscribed, not_subscribed = await check_subscription(message.from_user.id)
    
    if not is_subscribed and not_subscribed:
        text = "❌ Botdan foydalanish uchun quyidagi manbalarga a'zo bo'ling:\n\n"
        for ch in not_subscribed:
            if ch["type"] == "telegram":
                text += f"📢 Telegram kanal\n"
            elif ch["type"] == "instagram":
                text += f"📸 Instagram\n"
            elif ch["type"] == "youtube":
