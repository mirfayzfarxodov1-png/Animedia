async def view_media_by_id(message, media_id):
    try:
        cursor.execute("SELECT name, type, description, image_url, genre, status, season, total_parts, views, code, voice, sponsor, quality, rating, rating_count FROM media WHERE id = ?", (media_id,))
        media = cursor.fetchone()
        if not media:
            await safe_send_message(message.chat.id, "❌ Media topilmadi!")
            return
        name, media_type, desc, image, genre, status, season, total_parts, views, code, voice, sponsor, quality, rating, rating_count = media
        cursor.execute("UPDATE media SET views = views + 1 WHERE id = ?", (media_id,))
        conn.commit()
        
        post = format_media_post((name, media_type, genre, status, season, total_parts, views+1, code, voice, sponsor, quality, rating, rating_count))
        
        keyboard = InlineKeyboardMarkup(inline_keyboard=[
            [InlineKeyboardButton(text="📺 Tomosha qilish", callback_data=f"watch_parts_{media_id}")],
            [InlineKeyboardButton(text="⭐ Reyting", callback_data=f"rate_media_{media_id}")],
            [InlineKeyboardButton(text="🔙 Ortga", callback_data="back_to_start")]
        ])
        
        if image and (image.startswith("http") or image.startswith("AgA")):
            await safe_send_photo(message.chat.id, photo=image, caption=post, reply_markup=keyboard, parse_mode="HTML")
        else:
            await safe_send_message(message.chat.id, post, reply_markup=keyboard, parse_mode="HTML")
    except Exception as e:
        print(f"view_media_by_id xatosi: {e}")
        await safe_send_message(message.chat.id, "❌ Xatolik yuz berdi!")

